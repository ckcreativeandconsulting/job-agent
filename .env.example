# ============================================================
# Job Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env or google_credentials.json to git.
# ============================================================

# === OpenAI ===
OPENAI_API_KEY=your-openai-api-key-here

# === AI Scoring Mode ===
# Options: openai_only | ollama_only | hybrid | claude
# hybrid: Ollama pre-screens, OpenAI validates top candidates (recommended)
AI_MODE=hybrid

# === Model Selection ===
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_MODEL=qwen2.5:14b                        # requires Ollama running locally
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_TIMEOUT=180
CLAUDE_MODEL=claude-haiku-4-5                   # optional: only needed when AI_MODE=claude

# === Hybrid Scoring Threshold ===
# Ollama scores >= this value are re-scored by OpenAI for final validation
HYBRID_OPENAI_THRESHOLD=75

# === Job Volume ===
MAX_AI_JOBS=25          # Max auto-sourced jobs sent to AI scoring per run
MAX_MANUAL_SCORE=10     # Max manually-picked jobs scored per run

# === Embeddings (local Ollama) ===
OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings
OLLAMA_EMBED_MODEL=all-minilm                   # requires: ollama pull all-minilm
SEMANTIC_WEIGHT=12
SEMANTIC_MIN_SIM=0.30
EMBEDDING_CACHE_ENABLED=true

# === Google Sheets ===
# Path to your Google service account credentials JSON file.
# See README for instructions on creating a service account.
GOOGLE_CREDENTIALS_FILE=google_credentials.json
